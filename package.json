{
  "name": "maimaid-monorepo",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "nx": "nx",
    "graph": "nx graph",
    "list:ios": "nx run ios:list",
    "clean:ios": "nx run ios:clean",
    "build:ios": "nx run ios:build",
    "doctor:db": "nx run db:doctor",
    "status:db": "nx run db:status",
    "migrate:db": "nx run db:migrate",
    "reset:db": "nx run db:reset",
    "dev:web": "pnpm --filter dashboard dev",
    "build:web": "pnpm --filter dashboard build",
    "preview:web": "pnpm --filter dashboard start",
    "typecheck:web": "pnpm --filter dashboard exec tsc --noEmit",
    "check-env:web": "pnpm --filter dashboard check:env",
    "deploy:web": "pnpm --filter dashboard deploy",
    "dev:server": "nx run backend:dev",
    "build:server": "nx run backend:build",
    "test:server": "nx run backend:test",
    "migrate:server": "nx run backend:migrate"
  },
  "devDependencies": {
    "@nx/vite": "22.6.1",
    "@nx/web": "22.6.1",
    "@vitest/ui": "~4.0.0",
    "jiti": "2.4.2",
    "nx": "22.6.1",
    "vite": "^7.0.0",
    "vitest": "~4.0.0"
  }
}
