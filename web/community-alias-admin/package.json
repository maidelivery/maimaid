{
  "name": "community-alias-admin",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.20.0",
  "scripts": {
    "dev": "vite",
    "check:env": "node -e \"if (!process.env.VITE_SUPABASE_URL || !process.env.VITE_SUPABASE_ANON_KEY) { console.error('Missing VITE_SUPABASE_URL / VITE_SUPABASE_ANON_KEY'); process.exit(1); }\"",
    "build": "vite build",
    "preview": "vite preview",
    "cf:create": "wrangler pages project create maimaid-community-alias-admin --production-branch main",
    "deploy": "pnpm run check:env && pnpm run build && wrangler pages deploy dist --project-name maimaid-community-alias-admin"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.2",
    "@mui/material": "^7.3.2",
    "@mui/x-data-grid": "^8.14.1",
    "@mui/x-date-pickers": "^8.14.1",
    "@supabase/supabase-js": "^2.49.8",
    "dayjs": "^1.11.18",
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@types/react": "^19.1.16",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.2",
    "typescript": "^5.9.2",
    "vite": "^7.1.5"
  }
}
