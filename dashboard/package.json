{
	"name": "dashboard",
	"private": true,
	"version": "0.1.0",
	"type": "module",
	"scripts": {
		"dev": "next dev",
		"lint": "eslint .",
		"format": "prettier . --ignore-path ../.prettierignore --write",
		"format:check": "prettier . --ignore-path ../.prettierignore --check",
		"check:env": "node -e \"if (!process.env.NEXT_PUBLIC_BACKEND_URL) { console.error('Missing NEXT_PUBLIC_BACKEND_URL'); process.exit(1); }\"",
		"generate:headers": "node ./scripts/generate-security-headers.mjs",
		"build": "pnpm run generate:headers && next build",
		"start": "next start",
		"cf:create": "wrangler pages project create maimaid-dashboard --production-branch main",
		"deploy": "pnpm run check:env && pnpm run build && wrangler pages deploy out --project-name maimaid-dashboard"
	},
	"dependencies": {
		"@serenity-kit/opaque": "1.1.0",
		"@simplewebauthn/browser": "^12.0.0",
		"@tailwindcss/postcss": "^4.2.2",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"dayjs": "^1.11.18",
		"i18next": "^26.0.1",
		"i18next-browser-languagedetector": "^8.2.1",
		"input-otp": "^1.4.2",
		"lucide-react": "^1.6.0",
		"next": "^16.2.1",
		"next-themes": "^0.4.6",
		"qrcode": "^1.5.4",
		"radix-ui": "^1.4.3",
		"react": "^19.1.1",
		"react-dom": "^19.1.1",
		"react-i18next": "^17.0.1",
		"shadcn": "^4.1.0",
		"sonner": "^2.0.7",
		"tailwind-merge": "^3.5.0",
		"tw-animate-css": "^1.4.0",
		"zustand": "^5.0.8"
	},
	"devDependencies": {
		"@types/qrcode": "^1.5.6",
		"@types/react": "^19.1.16",
		"@types/react-dom": "^19.1.9",
		"eslint": "^9.38.0",
		"eslint-config-next": "^16.2.1",
		"prettier": "^3.6.2",
		"tailwindcss": "^4.2.2",
		"typescript": "^5.9.2"
	}
}
