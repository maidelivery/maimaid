{
	"name": "backend",
	"private": true,
	"version": "0.1.0",
	"type": "module",
	"scripts": {
		"postinstall": "prisma generate",
		"dev": "tsx watch src/server.ts",
		"build": "tsc -p tsconfig.build.json && pnpm run openapi:build",
		"openapi:build": "node scripts/generate-openapi.mjs",
		"lint": "eslint .",
		"format": "prettier . --ignore-path ../.prettierignore --write",
		"format:check": "prettier . --ignore-path ../.prettierignore --check",
		"start": "node dist/server.js",
		"podman:up": "podman compose up -d --build",
		"podman:down": "podman compose down",
		"podman:logs": "podman compose logs -f backend",
		"podman:reset": "podman compose down -v",
		"test": "vitest run",
		"test:watch": "vitest",
		"prisma:generate": "prisma generate",
		"prisma:migrate:dev": "prisma migrate dev",
		"prisma:migrate:deploy": "prisma migrate deploy",
		"user-handles:backfill": "tsx scripts/backfill-user-handles.ts",
		"prisma:studio": "prisma studio",
		"migrate": "prisma migrate deploy"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "^3.908.0",
		"@aws-sdk/s3-request-presigner": "^3.908.0",
		"@hono/node-server": "^1.14.4",
		"@hono/standard-validator": "^0.2.2",
		"@hono/tsyringe": "^1.0.1",
		"@prisma/adapter-pg": "^7.5.0",
		"@prisma/client": "^7.5.0",
		"@scalar/hono-api-reference": "^0.10.5",
		"@serenity-kit/opaque": "1.1.0",
		"@simplewebauthn/server": "^12.0.0",
		"@standard-schema/spec": "^1.1.0",
		"bcryptjs": "^3.0.2",
		"hono": "^4.9.8",
		"jose": "^6.1.0",
		"otpauth": "^9.4.1",
		"pg": "^8.17.0",
		"prisma": "^7.5.0",
		"reflect-metadata": "^0.2.2",
		"tsyringe": "^4.10.0",
		"typescript": "^5.9.2",
		"yaml": "^2.8.3",
		"zod": "^4.1.11"
	},
	"devDependencies": {
		"@eslint/js": "^9.38.0",
		"@types/node": "^24.5.2",
		"@types/pg": "8.20.0",
		"eslint": "^9.38.0",
		"globals": "^16.4.0",
		"prettier": "^3.6.2",
		"tsx": "^4.20.5",
		"typescript-eslint": "^8.46.1",
		"vitest": "^3.2.4"
	}
}
