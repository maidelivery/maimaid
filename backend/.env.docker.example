NODE_ENV=development
HOST=0.0.0.0
PORT=8787
APP_PUBLIC_URL=http://localhost:8787
CORS_ALLOWED_ORIGINS=http://localhost:3000
WEBAUTHN_ORIGIN=http://localhost:3000
WEBAUTHN_RP_ID=localhost

DATABASE_URL=postgresql://postgres:postgres@postgres:5432/maimaid

JWT_ISSUER=maimaid-backend
JWT_AUDIENCE=maimaid-clients
JWT_ACCESS_SECRET=replace-with-at-least-16-chars-access-secret
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000

RESEND_API_KEY=
RESEND_FROM_EMAIL=no-reply@example.com

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123

S3_ENDPOINT=http://minio:9000
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=maimaid-assets
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin123

CATALOG_SOURCE_URL=https://dp4p6x0xfi5o9.cloudfront.net/maimai/data.json
